# Root docker-compose.yml secrets (copy to .env; compose reads it automatically).
# CHANGE THESE before any real deployment.
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
COOKIE_SECURE=true
ADMIN_EMAIL=admin@thoth.dev
ADMIN_PASSWORD=change-me-please
# Bearer key protecting POST /mcp (the MCP server shares the public dashboard port).
# Leave empty ONLY on trusted networks: without it the endpoint is unauthenticated.
MCP_API_KEY=change-me-mcp-key
