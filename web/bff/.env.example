# Thoth BFF configuration (copy to .env for local dev; set in the container in prod)

# HTTP
PORT=3000
# comma-separated extra browser origins for CORS (dev only; prod is same-origin via nginx)
# CORS_ORIGIN=http://localhost:4200

# Engine pool — one URL per `thoth -server` replica; jobs lease one replica each
THOTH_ENGINE_URLS=http://localhost:8080
ENGINE_TIMEOUT_MS=120000

# Schema (the engine's JSON Schema; relative to the BFF's working directory)
SCHEMA_PATH=../../pricer/schema/thoth.schema.json

# Persistence (SQLite via better-sqlite3)
DB_PATH=data/thoth.sqlite
DB_SYNC=true

# Pricing job queue: memory (dev/test, no deps) | bullmq (prod, needs Redis)
QUEUE_DRIVER=memory
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — CHANGE THE SECRETS in any real deployment
JWT_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
COOKIE_SECURE=false
# initial admin seeded on first boot if the users table is empty
ADMIN_EMAIL=admin@thoth.dev
ADMIN_PASSWORD=change-me-please
