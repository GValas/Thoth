{
  // Single dev container carrying BOTH stacks: the C++ engine toolchain (g++, cmake,
  // CUDA) AND Node (the feature below) for the web/ workspaces (BFF + Angular). The
  // repo is mounted, so pricer/ and web/ are edited together. For full container
  // isolation (separate pricer/bff/web + Redis) see .devcontainer/docker-compose.dev.yml.
  "name": "Thoth monorepo (C++ engine + web)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {}
  },
  // NOTE: CUDA (nvcc) is installed directly in the Dockerfile, not via the
  // nvidia-cuda feature — the feature's full toolkit needs libtinfo5, which is
  // unavailable on Ubuntu 24.04. See .devcontainer/Dockerfile.
  // Attach the host NVIDIA GPU when one is available. "optional" keeps the
  // container working (CPU-only, mcl_gpu falls back to mcl) on a host with no GPU.
  "hostRequirements": {
    "gpu": "optional"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.cmake-tools",
        "ms-vscode.makefile-tools",
        "redhat.vscode-yaml",
        "tintinweb.graphviz-interactive-preview",
        "angular.ng-template",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "settings": {
        // Le terminal "Claude Code" (.vscode/tasks.json) s'ouvre dans le Panel.
        // On place le Panel à droite pour le sortir de la zone basse.
        "workbench.panel.defaultLocation": "right"
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "remoteUser": "vscode"
}
