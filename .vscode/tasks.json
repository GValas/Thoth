{
  "version": "2.0.0",
  "tasks": [
    {
      // Lance Claude Code dans un terminal dédié dès l'ouverture du dossier
      // (devcontainer). Si le CLI manque (ex. install réseau échouée au
      // post-create), il est (ré)installé puis exécuté. Repris d'ImmoAgent.
      "label": "Claude Code",
      "type": "shell",
      "command": "export PATH=\"$HOME/.local/bin:$PATH\"; command -v claude >/dev/null 2>&1 || curl -fsSL https://claude.ai/install.sh | bash; exec claude --dangerously-skip-permissions",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false,
        "group": "claude"
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      // Debug build (separate dir so the optimized Release build/ is untouched).
      // -g -O0 via CMAKE_BUILD_TYPE=Debug -> breakpoints land on the right lines.
      "label": "cmake: build debug",
      "type": "shell",
      "command": "cmake -S . -B build-debug -DCMAKE_BUILD_TYPE=Debug && cmake --build build-debug -j --target thoth",
      "group": "build",
      "problemMatcher": ["$gcc"]
    }
  ]
}
