{
  // CMake Tools tente de configurer le projet à l'ouverture et, faute de kit
  // (toolchain) sélectionné, affiche la notification « Scan for kits… ».
  // On désactive la configuration auto : le build passe par make/CMake en CLI.
  "cmake.configureOnOpen": false,
  "cmake.showOptionsMovedNotification": false,

  // JSON Schema for the Thoth YAML config: inline validation + autocomplete in
  // redhat.vscode-yaml. Scoped to the maintained INPUT samples only (not the
  // generated *.out.yaml results). To validate a new config, add it here or put
  // a modeline at the top of the file:
  //   # yaml-language-server: $schema=./schema/thoth.schema.json
  // NB: JSON Schema cannot key on a YAML tag, so each tagged object is checked
  // against anyOf the kind definitions; a typo'd field matches none and is
  // flagged, while the three structurally identical curves match several.
  "yaml.schemas": {
    "./schema/thoth.schema.json": [
      "samples/simple_call.yaml",
      "samples/matrix.yaml",
      "samples/heston_call.yaml"
    ]
  },
  // Turn on the editor guidance the schema drives (these are the defaults, set
  // explicitly so a user-level override does not silently disable them).
  "yaml.validate": true,
  "yaml.hover": true,
  "yaml.completion": true,

  // Each Thoth object declares its kind via a local YAML tag (name: !equity {...}).
  // Declare them so the YAML linter (redhat.vscode-yaml) stops reporting
  // "Unresolved tag: !...". All kinds are mappings.
  "yaml.customTags": [
    "!pricer mapping",
    "!pricer_configuration mapping",
    "!debug_configuration mapping",
    "!mcl_configuration mapping",
    "!pde_configuration mapping",
    "!book mapping",
    "!vanilla mapping",
    "!barrier mapping",
    "!variance_swap mapping",
    "!equity mapping",
    "!composite mapping",
    "!basket mapping",
    "!rainbow mapping",
    "!currency mapping",
    "!forex mapping",
    "!yield_curve mapping",
    "!repo_curve mapping",
    "!continuous_dividends_curve mapping",
    "!bs_volatility mapping",
    "!sabr_volatility mapping",
    "!heston_volatility mapping",
    "!correlation_matrix mapping",
    "!historical_volatility_computation mapping",
    "!historical_correlation_computation mapping",
    "!sequence mapping",
    "!simple_fixing_data mapping",
    "!simple_weighted_calendar mapping"
  ],

  // Color local YAML tags (e.g. !pricer, !vanilla) in red. Under the
  // active redhat.vscode-yaml grammar, a node tag like "!pricer" is scoped
  // storage.type.tag-handle.yaml. NB: entity.name.tag.yaml is the mapping-KEY
  // scope, so do not use it here or the fields turn red instead of the tags.
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "storage.type.tag-handle.yaml"
        ],
        "settings": {
          "foreground": "#ff84b3", 
        }
      }
    ]
  }
}
